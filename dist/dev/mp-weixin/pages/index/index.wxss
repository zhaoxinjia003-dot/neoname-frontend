/* 参考 generate-baby-names app/globals.css 配色 */
.page.data-v-83a5a03c {
  min-height: 100vh;
  background: #f7f4f0;
  padding-bottom: 64rpx;
  box-sizing: border-box;
}
.top-spacer.data-v-83a5a03c {
  height: 16rpx;
}

/* Header */
.header.data-v-83a5a03c {
  margin: 32rpx;
  border-radius: 32rpx;
  overflow: hidden;
}
.header-bg.data-v-83a5a03c {
  width: 100%;
  display: block;
}

/* 为何选择我们 */
.trust-section.data-v-83a5a03c {
  margin: 24rpx 32rpx;
  background: #fdf9f2;
  border: 1rpx solid #e0d9cf;
  border-radius: 24rpx;
  padding: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}
.trust-title-wrap.data-v-83a5a03c {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-bottom: 12rpx;
}
.trust-title-bar.data-v-83a5a03c {
  width: 6rpx;
  height: 24rpx;
  border-radius: 3rpx;
  background: #c85a28;
}
.trust-title.data-v-83a5a03c {
  font-size: 26rpx;
  font-weight: 600;
  color: #2d2620;
  letter-spacing: 0.02em;
}
.trust-grid.data-v-83a5a03c {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 12rpx;
}
.trust-card.data-v-83a5a03c {
  background: rgba(235, 229, 220, 0.6);
  border: 1rpx solid rgba(224, 217, 207, 0.6);
  border-radius: 16rpx;
  padding: 12rpx;
}
.trust-card-icon-wrap.data-v-83a5a03c {
  width: 32rpx;
  height: 32rpx;
  border-radius: 8rpx;
  background: rgba(200, 90, 40, 0.1);
  align-items: center;
  justify-content: center;
  display: flex;
  margin-bottom: 6rpx;
}
.trust-card-icon.data-v-83a5a03c {
  font-size: 18rpx;
  color: #c85a28;
}
.trust-card-title.data-v-83a5a03c {
  font-size: 22rpx;
  font-weight: 600;
  color: #2d2620;
  display: block;
  margin-bottom: 2rpx;
}
.trust-card-desc.data-v-83a5a03c {
  font-size: 18rpx;
  color: #7a726b;
  line-height: 1.3;
}

/* 表单卡片 */
.form-card.data-v-83a5a03c {
  margin: 32rpx;
  background: #fdf9f2;
  border: 1rpx solid #e0d9cf;
  border-radius: 32rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
  overflow: hidden;
}
.form-head.data-v-83a5a03c {
  padding: 40rpx 40rpx 24rpx;
}
.form-head-title.data-v-83a5a03c {
  font-size: 34rpx;
  font-weight: 600;
  color: #2d2620;
  letter-spacing: 0.02em;
  display: block;
}
.form-head-desc.data-v-83a5a03c {
  font-size: 24rpx;
  color: #7a726b;
  margin-top: 8rpx;
  display: block;
}
.form-body.data-v-83a5a03c {
  padding: 0 40rpx;
}
.form-row.data-v-83a5a03c {
  padding: 28rpx 0;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}
.form-row.border-b.data-v-83a5a03c {
  border-bottom: 1rpx solid #e0d9cf;
}
.form-label.data-v-83a5a03c {
  font-size: 24rpx;
  color: #7a726b;
  font-weight: 500;
}
.form-label-optional.data-v-83a5a03c {
  opacity: 0.7;
}
.form-input.data-v-83a5a03c {
  font-size: 30rpx;
  color: #2d2620;
  padding: 0;
  background: transparent;
}
.form-input.data-v-83a5a03c::-moz-placeholder {
  color: rgba(122, 114, 107, 0.5);
}
.form-input.data-v-83a5a03c::placeholder {
  color: rgba(122, 114, 107, 0.5);
}
.form-options.data-v-83a5a03c {
  display: flex;
  gap: 24rpx;
}
.form-option.data-v-83a5a03c {
  flex: 1;
  padding: 20rpx;
  border-radius: 24rpx;
  text-align: center;
  font-size: 26rpx;
  font-weight: 500;
  background: #ebe5dc;
  color: #2d2620;
}
.form-option--active.data-v-83a5a03c {
  background: #c85a28;
  color: #fdf9f2;
  box-shadow: 0 2rpx 8rpx rgba(200, 90, 40, 0.3);
}
.form-picker.data-v-83a5a03c {
  font-size: 30rpx;
  color: #2d2620;
}
.form-picker--placeholder.data-v-83a5a03c {
  color: rgba(122, 114, 107, 0.5);
}
.form-footer.data-v-83a5a03c {
  padding: 24rpx 40rpx 40rpx;
}
.btn-submit.data-v-83a5a03c {
  width: 100%;
  padding: 28rpx;
  border-radius: 24rpx;
  background: #c85a28;
  color: #fdf9f2;
  font-size: 30rpx;
  font-weight: 600;
  box-shadow: 0 4rpx 16rpx rgba(200, 90, 40, 0.35);
  border: none;
}
.btn-submit-text.data-v-83a5a03c {
  color: #fdf9f2;
}
.page-note.data-v-83a5a03c {
  text-align: center;
  font-size: 22rpx;
  color: rgba(122, 114, 107, 0.85);
  line-height: 1.5;
  margin: 32rpx 48rpx 0;
}